   GPU_ARCH_AMD_GFX1102 = CAT(GpuVendor::kAMD, 0x1102),
   GPU_ARCH_AMD_GFX1103 = CAT(GpuVendor::kAMD, 0x1103),
+  GPU_ARCH_AMD_GFX1150 = CAT(GpuVendor::kAMD, 0x1150),
+  GPU_ARCH_AMD_GFX1151 = CAT(GpuVendor::kAMD, 0x1151),
